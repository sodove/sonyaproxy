# GONIC connection (host network — localhost reaches the server's gonic)
GONIC_URL=http://localhost:4533
GONIC_USER=admin
GONIC_PASS=secret
GONIC_MUSIC_DIR=/music

# Proxy (host network — binds directly to server port)
PROXY_PORT=4040

# yt-dlp
PREFETCH_COUNT=3
YTDLP_FORMAT=bestaudio
YTDLP_AUDIO_FORMAT=mp3
YTDLP_PATH=yt-dlp

# Database (inside docker volume)
DB_PATH=/app/data/sonyaproxy.db

# Auto-populate
AUTOPOP_ENABLED=true
AUTOPOP_FLAVOR_PATH=flavor.yml
AUTOPOP_STARTUP_DELAY=60
